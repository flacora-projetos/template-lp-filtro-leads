# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Tracking client-side (GA4 + GTM + Meta Pixel base) — ver index.html e
# docs/CUSTOMIZAR-POR-CLIENTE.md. Se uma destas ficar vazia, o script
# correspondente simplesmente não inicializa (sem erro) — útil pra clientes
# que ainda não têm uma das contas configurada.
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
GTM_CONTAINER_ID="GTM-XXXXXXX"

# WhatsApp que recebe a mensagem final do lead qualificado
# (src/components/QualificationModal.tsx), formato internacional sem "+"
# (DDI+DDD+número, ex.: 55 62 90000-0000 → "5562900000000").
WHATSAPP_NUMBER="55DDD00000000"

# Meta Conversions API (CAPI) — META_PIXEL_ID também é usado no client-side
# (fbq init em index.html) e precisa bater com o pixel configurado no Meta
# Events Manager. ENABLE_META_CAPI="false" desliga o envio DE PROPÓSITO
# (fica explícito no log) sem precisar remover as credenciais.
META_PIXEL_ID="0000000000000000"
META_ACCESS_TOKEN=""
META_TEST_EVENT_CODE=""
# ENABLE_META_CAPI="false"

# Google Ads Enhanced Conversions (Data Manager API) — demais vars
# (GOOGLE_SA_KEY_B64, GOOGLE_ADS_CUSTOMER_ID, GOOGLE_ADS_CONVERSION_ACTION_ID)
# não documentadas aqui historicamente, configurar direto no ambiente de deploy.
# ENABLE_GOOGLE_EC="false" desliga o envio DE PROPÓSITO (fica explícito no
# log) sem precisar remover as credenciais.
# ENABLE_GOOGLE_EC="false"
# ctId da ação de conversão "lead qualificado" — NOME e status-gatilho do
# funil que dispara isso são customização manual por cliente, ver
# docs/CUSTOMIZAR-POR-CLIENTE.md e api/leads.ts dispatchConsultaRealizada.
GOOGLE_ADS_CONVERSION_ACTION_ID_QUALIFICADO="0000000000"

# Supabase (mini CRM administrativo — ver docs/handoff-mini-crm-opus.md)
# URL do projeto: Supabase > Project Settings > Data API > Project URL
SUPABASE_URL="COLE_AQUI_A_PROJECT_URL"
# Chave pública, usada no front-end do /admin para login (Project Settings > API Keys > anon/public)
SUPABASE_ANON_KEY="COLE_AQUI_A_ANON_KEY"
# Chave secreta, USO EXCLUSIVO NO SERVIDOR (rotas /api). Nunca expor no front-end.
# Project Settings > API Keys > service_role
SUPABASE_SERVICE_ROLE_KEY="COLE_AQUI_A_SERVICE_ROLE_KEY"

# (Opcional) Allow-list de e-mails com acesso ao /admin, separados por vírgula.
# Se ausente, usa a lista padrão embutida em lib/requireAuth.ts (os 4 e-mails
# aprovados). Defina apenas se precisar mudar quem tem acesso sem editar código.
# ADMIN_EMAILS="karynemag@gmail.com,flacora@gmail.com,contato@nandacora.com.br,equipe@nandacora.com.br"
